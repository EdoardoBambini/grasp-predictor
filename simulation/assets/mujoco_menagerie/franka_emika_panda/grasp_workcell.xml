<mujoco model="panda_grasp_workcell">
  <include file="panda.xml"/>

  <statistic center="0.45 0 0.35" extent="1.2"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" iterations="80" noslip_iterations="8" tolerance="1e-10"/>

  <visual>
    <headlight diffuse="0.52 0.52 0.52" ambient="0.18 0.18 0.18" specular="0.1 0.1 0.1"/>
    <rgba haze="0.05 0.08 0.12 1"/>
    <quality shadowsize="4096"/>
    <map znear="0.01" zfar="50"/>
    <global azimuth="130" elevation="-22"/>
  </visual>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient"
             rgb1="0.78 0.84 0.92" rgb2="0.58 0.64 0.74" width="512" height="512"/>
    <texture name="grid_tex" type="2d" builtin="checker"
             rgb1="0.73 0.74 0.75" rgb2="0.82 0.83 0.84"
             width="256" height="256" mark="edge" markrgb="0.63 0.64 0.66"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="8 8" texuniform="true" reflectance="0.05"/>
    <material name="table_mat" specular="0.35" shininess="0.45" rgba="0.56 0.56 0.58 1"/>
    <material name="dropzone_mat" specular="0.2" shininess="0.3" rgba="0.24 0.24 0.26 1"/>
    <material name="orange_mat" specular="0.5" shininess="0.4" rgba="1.0 0.4 0.1 1"/>
    <material name="blue_mat" specular="0.5" shininess="0.4" rgba="0.2 0.6 1.0 1"/>
    <material name="pink_mat" specular="0.5" shininess="0.4" rgba="0.9 0.2 0.5 1"/>
    <material name="green_mat" specular="0.5" shininess="0.4" rgba="0.22 0.85 0.35 1"/>
    <material name="black_mat" specular="0.25" shininess="0.2" rgba="0.07 0.07 0.08 1"/>
    <material name="gray_mat" specular="0.25" shininess="0.2" rgba="0.52 0.54 0.56 1"/>
    <mesh name="triangle_mesh" file="triangle_black.obj" scale="1 1 1"/>
    <mesh name="hemisphere_mesh" file="hemisphere_gray.obj" scale="1 1 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.01" material="grid_mat"/>
    <light name="spotlight1" pos="0.5 -0.8 1.8" dir="0 0.5 -1"
           diffuse="0.55 0.55 0.56" specular="0.2 0.2 0.2" castshadow="true" cutoff="60"/>
    <light name="spotlight2" pos="0.8 0.6 1.5" dir="-0.3 -0.3 -1"
           diffuse="0.42 0.42 0.44" specular="0.15 0.15 0.15" castshadow="true" cutoff="50"/>

    <body name="table" pos="0.5 0.0 0.2">
      <geom name="table_top" type="box" size="0.35 0.45 0.02" material="table_mat" mass="50" friction="1.4 0.01 0.001"/>
      <geom type="cylinder" size="0.025 0.1" pos="-0.30 -0.40 -0.12" rgba="0.38 0.38 0.40 1"/>
      <geom type="cylinder" size="0.025 0.1" pos="0.30 -0.40 -0.12" rgba="0.38 0.38 0.40 1"/>
      <geom type="cylinder" size="0.025 0.1" pos="-0.30 0.40 -0.12" rgba="0.38 0.38 0.40 1"/>
      <geom type="cylinder" size="0.025 0.1" pos="0.30 0.40 -0.12" rgba="0.38 0.38 0.40 1"/>
    </body>

    <body name="drop_zone" pos="0.55 0.30 0.25">
      <geom name="dropzone_surface" type="cylinder" size="0.17 0.05"
            material="dropzone_mat" mass="40" friction="2.2 0.01 0.001"/>
    </body>

    <body name="cube_orange" pos="0.45 -0.12 0.24">
      <freejoint name="cube_orange_free"/>
      <geom name="cube_orange_geom" type="box" size="0.02 0.02 0.02"
            material="orange_mat" mass="0.10" friction="1.8 0.01 0.001" condim="6" margin="0.003"
            solref="0.004 1" solimp="0.995 0.999 0.0001"/>
    </body>

    <body name="cube_blue" pos="0.35 -0.17 0.24">
      <freejoint name="cube_blue_free"/>
      <geom name="cube_blue_geom" type="box" size="0.02 0.02 0.02"
            material="blue_mat" mass="0.10" friction="1.8 0.01 0.001" condim="6" margin="0.003"
            solref="0.004 1" solimp="0.995 0.999 0.0001"/>
    </body>

    <body name="cube_pink" pos="0.55 -0.08 0.24">
      <freejoint name="cube_pink_free"/>
      <geom name="cube_pink_geom" type="box" size="0.02 0.02 0.02"
            material="pink_mat" mass="0.10" friction="1.8 0.01 0.001" condim="6" margin="0.003"
            solref="0.004 1" solimp="0.995 0.999 0.0001"/>
    </body>

    <body name="sphere_green" pos="0.50 -0.19 0.24">
      <freejoint name="sphere_green_free"/>
      <geom name="sphere_green_geom" type="sphere" size="0.02"
            material="green_mat" mass="0.09" friction="1.6 0.01 0.001" condim="6" margin="0.003"
            solref="0.004 1" solimp="0.995 0.999 0.0001"/>
    </body>

    <body name="triangle_black" pos="0.60 -0.16 0.242">
      <freejoint name="triangle_black_free"/>
      <geom name="triangle_black_geom" type="mesh" mesh="triangle_mesh"
            material="black_mat" mass="0.10" friction="1.9 0.01 0.001" condim="6" margin="0.003"
            solref="0.004 1" solimp="0.995 0.999 0.0001"/>
    </body>

    <body name="hemisphere_gray" pos="0.40 -0.05 0.231">
      <freejoint name="hemisphere_gray_free"/>
      <geom name="hemisphere_gray_geom" type="mesh" mesh="hemisphere_mesh"
            material="gray_mat" mass="0.09" friction="1.8 0.01 0.001" condim="6" margin="0.003"
            solref="0.004 1" solimp="0.995 0.999 0.0001"/>
    </body>
  </worldbody>

  <sensor>
    <jointactuatorfrc name="torque_j1" joint="joint1"/>
    <jointactuatorfrc name="torque_j2" joint="joint2"/>
    <jointactuatorfrc name="torque_j3" joint="joint3"/>
    <jointactuatorfrc name="torque_j4" joint="joint4"/>
    <jointactuatorfrc name="torque_j5" joint="joint5"/>
    <jointactuatorfrc name="torque_j6" joint="joint6"/>
    <jointactuatorfrc name="torque_j7" joint="joint7"/>
    <jointactuatorfrc name="force_finger_l" joint="finger_joint1"/>
    <jointactuatorfrc name="force_finger_r" joint="finger_joint2"/>
  </sensor>
</mujoco>
